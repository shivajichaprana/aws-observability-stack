      "targets": [
        {"namespace": "AWS/RDS", "metricName": "ReadIOPS", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "A", "alias": "read"},
        {"namespace": "AWS/RDS", "metricName": "WriteIOPS", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "B", "alias": "write"}
      ]
    },
    {
      "type": "timeseries", "id": 32, "title": "Read/write latency",
      "datasource": {"type": "cloudwatch", "uid": "${DS_CW}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"namespace": "AWS/RDS", "metricName": "ReadLatency", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "A", "alias": "read"},
        {"namespace": "AWS/RDS", "metricName": "WriteLatency", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "B", "alias": "write"}
      ]
    },
    {
      "type": "timeseries", "id": 33, "title": "Free storage trend",
      "datasource": {"type": "cloudwatch", "uid": "${DS_CW}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 33},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [{"namespace": "AWS/RDS", "metricName": "FreeStorageSpace", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "300", "refId": "A"}]
    },
    {
      "type": "timeseries", "id": 34, "title": "Burst balance + EBS byte balance",
      "datasource": {"type": "cloudwatch", "uid": "${DS_CW}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 33},
