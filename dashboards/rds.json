      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"namespace": "AWS/RDS", "metricName": "AbortedClients", "statistic": "Sum", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "A", "alias": "aborted clients"},
        {"namespace": "AWS/RDS", "metricName": "Deadlocks", "statistic": "Sum", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "B", "alias": "deadlocks"}
      ]
    },
    {"type": "row", "id": 30, "title": "Storage and IOPS", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24}, "panels": []},
