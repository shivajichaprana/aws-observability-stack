  "description": "RDS / Aurora health: CPU, connections, IOPS, replica lag, free storage, deadlocks. Backed by the CloudWatch data source in Managed Grafana. Use to triage database-backed services when the workload golden-signals dashboard shows latency or error spikes.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "liveNow": false,
  "panels": [
    {"type": "row", "id": 1, "title": "Instance summary", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "panels": []},
    {
      "type": "stat", "id": 2, "title": "Active CPU",
      "datasource": {"type": "cloudwatch", "uid": "${DS_CW}"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"namespace": "AWS/RDS", "metricName": "CPUUtilization", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "A"}]
    },
    {
      "type": "stat", "id": 3, "title": "Connections",
      "datasource": {"type": "cloudwatch", "uid": "${DS_CW}"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 200}, {"color": "red", "value": 800}]}}},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"namespace": "AWS/RDS", "metricName": "DatabaseConnections", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "A"}]
    },
    {
      "type": "stat", "id": 4, "title": "Free storage",
      "datasource": {"type": "cloudwatch", "uid": "${DS_CW}"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "fieldConfig": {"defaults": {"unit": "bytes", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 5368709120}, {"color": "green", "value": 21474836480}]}}},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"namespace": "AWS/RDS", "metricName": "FreeStorageSpace", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "A"}]
    },
    {
      "type": "stat", "id": 5, "title": "Replica lag",
      "datasource": {"type": "cloudwatch", "uid": "${DS_CW}"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 10}, {"color": "red", "value": 60}]}}},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"namespace": "AWS/RDS", "metricName": "ReplicaLag", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "A"}]
    },
    {"type": "row", "id": 10, "title": "CPU and memory", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6}, "panels": []},
    {
      "type": "timeseries", "id": 11, "title": "CPU utilization",
      "datasource": {"type": "cloudwatch", "uid": "${DS_CW}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 7},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "thresholdsStyle": {"mode": "line"}}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 90}]}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}, "tooltip": {"mode": "multi"}},
      "targets": [{"namespace": "AWS/RDS", "metricName": "CPUUtilization", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "A"}]
