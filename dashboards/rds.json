      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"namespace": "AWS/RDS", "metricName": "FreeableMemory", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "A", "alias": "freeable"},
        {"namespace": "AWS/RDS", "metricName": "SwapUsage", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "B", "alias": "swap"}
      ]
    },
    {"type": "row", "id": 20, "title": "Connections + queries", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15}, "panels": []},
    {
      "type": "timeseries", "id": 21, "title": "Database connections",
