        {"namespace": "AWS/RDS", "metricName": "NetworkTransmitThroughput", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "B", "alias": "tx"}
      ]
    }
