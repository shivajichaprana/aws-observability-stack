      "targets": [
        {"namespace": "AWS/RDS", "metricName": "BurstBalance", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "A", "alias": "burst balance"},
        {"namespace": "AWS/RDS", "metricName": "EBSByteBalance%", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "B", "alias": "EBS byte balance"},
        {"namespace": "AWS/RDS", "metricName": "EBSIOBalance%", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "C", "alias": "EBS IO balance"}
      ]
    },
    {"type": "row", "id": 40, "title": "Replication", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 41}, "panels": []},
    {
      "type": "timeseries", "id": 41, "title": "Replica lag",
      "datasource": {"type": "cloudwatch", "uid": "${DS_CW}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 42},
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"thresholdsStyle": {"mode": "line"}}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 60}]}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [{"namespace": "AWS/RDS", "metricName": "ReplicaLag", "statistic": "Average", "dimensions": {"DBInstanceIdentifier": "$instance"}, "region": "$region", "period": "60", "refId": "A"}]
    },
    {
      "type": "timeseries", "id": 42, "title": "Network throughput",
      "datasource": {"type": "cloudwatch", "uid": "${DS_CW}"},
