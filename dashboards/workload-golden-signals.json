{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true, "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts", "type": "dashboard"
      },
      {
        "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
        "enable": true,
        "expr": "max(kube_deployment_status_replicas_updated{cluster=~\"$cluster\",namespace=~\"$namespace\",deployment=~\"$workload\"}) by (deployment) > 0",
        "hide": false,
        "iconColor": "rgba(255, 96, 96, 1)",
        "name": "Deployment rollouts",
        "step": "1m",
        "tagKeys": "deployment",
        "titleFormat": "Rollout"
      }
    ]
  },
  "description": "RED metrics (Rate / Errors / Duration) per workload, plus saturation. Designed around OpenTelemetry HTTP server semantic conventions; works with anything that exports http.server.duration / http.server.request.count via OTLP. Use this dashboard to triage a single service during an incident.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"title": "EKS cluster overview", "type": "dashboards", "asDropdown": true, "icon": "external link", "tags": ["eks"]}
  ],
  "liveNow": false,
  "panels": [
    {"type": "row", "id": 1, "title": "Service-level summary", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "panels": []},
    {
      "type": "stat", "id": 2, "title": "Request rate (RPS)",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "palette-classic"}}},
      "options": {"colorMode": "value", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum(rate(http_server_request_count_total{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\"}[5m]))", "refId": "A"}]
    },
    {
      "type": "stat", "id": 3, "title": "Error ratio (5xx)",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.01}, {"color": "red", "value": 0.05}]}}},
      "options": {"colorMode": "background", "graphMode": "area", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum(rate(http_server_request_count_total{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\",http_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_request_count_total{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\"}[5m])), 1)", "refId": "A"}]
    },
    {
      "type": "stat", "id": 4, "title": "Duration p95",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "fieldConfig": {"defaults": {"unit": "s", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.3}, {"color": "red", "value": 1}]}}},
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_seconds_bucket{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\"}[5m])))", "refId": "A"}]
    },
    {
      "type": "stat", "id": 5, "title": "Pod count",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "palette-classic"}}},
      "options": {"colorMode": "value", "reduceOptions": {"calcs": ["lastNotNull"]}},
      "targets": [{"expr": "sum(kube_pod_info{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\".*$workload.*\"})", "refId": "A"}]
    },
    {"type": "row", "id": 10, "title": "Rate", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6}, "panels": []},
    {
      "type": "timeseries", "id": 11, "title": "RPS by route",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 7},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 10, "stacking": {"mode": "normal"}}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [{"expr": "sum by (http_route) (rate(http_server_request_count_total{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\"}[5m]))", "legendFormat": "{{http_route}}", "refId": "A"}]
    },
    {
      "type": "timeseries", "id": 12, "title": "RPS by HTTP status code class",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 7},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "fillOpacity": 20, "stacking": {"mode": "normal"}}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]}, "tooltip": {"mode": "multi"}},
      "targets": [{"expr": "sum by (http_status_code) (rate(http_server_request_count_total{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\"}[5m]))", "legendFormat": "{{http_status_code}}", "refId": "A"}]
    },
    {"type": "row", "id": 20, "title": "Errors", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15}, "panels": []},
    {
      "type": "timeseries", "id": 21, "title": "Error rate by route (5xx + 4xx>=400)",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "lastNotNull"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum by (http_route) (rate(http_server_request_count_total{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\",http_status_code=~\"5..\"}[5m]))", "legendFormat": "5xx {{http_route}}", "refId": "A"},
        {"expr": "sum by (http_route) (rate(http_server_request_count_total{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\",http_status_code=~\"4..\"}[5m]))", "legendFormat": "4xx {{http_route}}", "refId": "B"}
      ]
    },
    {
      "type": "timeseries", "id": 22, "title": "Error ratio with SLO line (99.9%)",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "fieldConfig": {"defaults": {"unit": "percentunit", "custom": {"thresholdsStyle": {"mode": "line"}}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.001}]}}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [{"expr": "sum(rate(http_server_request_count_total{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\",http_status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_request_count_total{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\"}[5m])), 1)", "legendFormat": "Error ratio", "refId": "A"}]
    },
    {"type": "row", "id": 30, "title": "Duration", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24}, "panels": []},
    {
      "type": "timeseries", "id": 31, "title": "Latency percentiles (p50/p95/p99)",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_duration_seconds_bucket{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\"}[5m])))", "legendFormat": "p50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_duration_seconds_bucket{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\"}[5m])))", "legendFormat": "p95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_duration_seconds_bucket{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\"}[5m])))", "legendFormat": "p99", "refId": "C"}
      ]
    },
    {
      "type": "heatmap", "id": 32, "title": "Latency heatmap",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
      "options": {"calculate": false, "yAxis": {"unit": "s"}, "color": {"scheme": "Spectral", "mode": "scheme"}},
      "targets": [{"expr": "sum by (le) (rate(http_server_duration_seconds_bucket{cluster=~\"$cluster\",namespace=~\"$namespace\",service=~\"$workload\"}[1m]))", "format": "heatmap", "legendFormat": "{{le}}", "refId": "A"}]
    },
    {"type": "row", "id": 40, "title": "Saturation", "collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 33}, "panels": []},
    {
      "type": "timeseries", "id": 41, "title": "Pod CPU usage vs request",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 34},
      "fieldConfig": {"defaults": {"unit": "cores"}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\".*$workload.*\",container!=\"\"}[5m]))", "legendFormat": "used {{pod}}", "refId": "A"},
        {"expr": "sum by (pod) (kube_pod_container_resource_requests{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\".*$workload.*\",resource=\"cpu\"})", "legendFormat": "request {{pod}}", "refId": "B"}
      ]
    },
    {
      "type": "timeseries", "id": 42, "title": "Pod memory usage vs limit",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 34},
      "fieldConfig": {"defaults": {"unit": "bytes"}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull", "max"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "sum by (pod) (container_memory_working_set_bytes{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\".*$workload.*\",container!=\"\"})", "legendFormat": "used {{pod}}", "refId": "A"},
        {"expr": "sum by (pod) (kube_pod_container_resource_limits{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\".*$workload.*\",resource=\"memory\"})", "legendFormat": "limit {{pod}}", "refId": "B"}
      ]
    },
    {
      "type": "timeseries", "id": 43, "title": "Container restarts",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 42},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["max", "lastNotNull"]}, "tooltip": {"mode": "multi"}},
      "targets": [{"expr": "sum by (pod) (increase(kube_pod_container_status_restarts_total{cluster=~\"$cluster\",namespace=~\"$namespace\",pod=~\".*$workload.*\"}[5m]))", "legendFormat": "{{pod}}", "refId": "A"}]
    },
    {
      "type": "timeseries", "id": 44, "title": "HPA replica state",
      "datasource": {"type": "prometheus", "uid": "${DS_AMP}"},
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 42},
      "fieldConfig": {"defaults": {"unit": "short"}},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {"expr": "max by (horizontalpodautoscaler) (kube_horizontalpodautoscaler_status_current_replicas{cluster=~\"$cluster\",namespace=~\"$namespace\",horizontalpodautoscaler=~\".*$workload.*\"})", "legendFormat": "current {{horizontalpodautoscaler}}", "refId": "A"},
        {"expr": "max by (horizontalpodautoscaler) (kube_horizontalpodautoscaler_status_desired_replicas{cluster=~\"$cluster\",namespace=~\"$namespace\",horizontalpodautoscaler=~\".*$workload.*\"})", "legendFormat": "desired {{horizontalpodautoscaler}}", "refId": "B"},
        {"expr": "max by (horizontalpodautoscaler) (kube_horizontalpodautoscaler_spec_max_replicas{cluster=~\"$cluster\",namespace=~\"$namespace\",horizontalpodautoscaler=~\".*$workload.*\"})", "legendFormat": "max {{horizontalpodautoscaler}}", "refId": "C"}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["workload", "red", "golden-signals", "service"],
  "templating": {
    "list": [
      {"name": "DS_AMP", "type": "datasource", "query": "prometheus", "label": "Prometheus data source", "current": {"text": "AMP", "value": "AMP"}, "hide": 0},
      {"name": "cluster", "type": "query", "datasource": {"type": "prometheus", "uid": "${DS_AMP}"}, "definition": "label_values(kube_node_info, cluster)", "query": {"query": "label_values(kube_node_info, cluster)", "refId": "StandardVariableQuery"}, "refresh": 2, "includeAll": false, "multi": false, "label": "Cluster"},
      {"name": "namespace", "type": "query", "datasource": {"type": "prometheus", "uid": "${DS_AMP}"}, "definition": "label_values(kube_namespace_created{cluster=~\"$cluster\"}, namespace)", "query": {"query": "label_values(kube_namespace_created{cluster=~\"$cluster\"}, namespace)", "refId": "StandardVariableQuery"}, "refresh": 2, "includeAll": false, "multi": false, "label": "Namespace"},
      {"name": "workload", "type": "query", "datasource": {"type": "prometheus", "uid": "${DS_AMP}"}, "definition": "label_values(http_server_request_count_total{cluster=~\"$cluster\",namespace=~\"$namespace\"}, service)", "query": {"query": "label_values(http_server_request_count_total{cluster=~\"$cluster\",namespace=~\"$namespace\"}, service)", "refId": "StandardVariableQuery"}, "refresh": 2, "includeAll": false, "multi": false, "label": "Workload (service)"}
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {"refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h", "6h", "12h", "1d"]},
  "timezone": "",
  "title": "Workload Golden Signals (RED + saturation)",
  "uid": "workload-golden-signals",
  "version": 1,
  "weekStart": ""
}
